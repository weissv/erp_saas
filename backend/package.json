{
  "name": "erp-backend",
  "version": "1.0.0",
  "description": "Backend for the School/Kindergarten ERP System",
  "main": "dist/index.js",
  "author": "Izumi Amano",
  "license": "ISC",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "postinstall": "prisma generate"
  },
