    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.73.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "express": "^4.18.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "openai": "^4.77.0",
    "prisma": "^6.19.0",
    "socket.io": "^4.8.3",
    "stripe": "^22.0.1",
