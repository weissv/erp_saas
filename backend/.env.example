# URL для подключения к базе данных PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/erp_db?schema=public"

# ============================================================================
# MULTI-TENANT / CONTROL PLANE
# ============================================================================

# Connection string for the Control Plane (master) database.
# Stores tenant metadata and global settings.
MASTER_DATABASE_URL="postgresql://user:password@localhost:5432/erp_master?schema=public"

# Base domain used to extract tenant subdomains.
# e.g. with BASE_DOMAIN="mezon.app", a request to hogwarts.mezon.app resolves tenant "hogwarts".
BASE_DOMAIN="mezon.app"

# Maximum number of tenant Prisma clients cached in memory (default: 50).
TENANT_PRISMA_CACHE_SIZE="50"

# Порт, на котором будет работать API
PORT=4000

# Секретный ключ для подписи JWT токенов
JWT_SECRET="dev_secret_change_me"

# Режим запуска приложения
NODE_ENV="development"

# ============================================================================
# AI / ИИ-АССИСТЕНТ (ОБЯЗАТЕЛЬНЫЕ)
# ============================================================================

# Gemini API Key - для генерации embeddings (векторов) и семантического поиска
# Получить: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Groq API Key - для чат-бота / AI-ассистента
# Получить: https://console.groq.com/keys
GROQ_API_KEY="your_groq_api_key_here"

# ============================================================================
# GOOGLE DRIVE (ОПЦИОНАЛЬНО)
# ============================================================================
# Для автоматической синхронизации документов из Google Drive в базу знаний
# Если не нужно - можно не указывать

# Google Drive API Key
# 1. Перейти: https://console.developers.google.com/
# 2. Создать проект
# 3. Включить Google Drive API
# 4. Создать API Key
GOOGLE_DRIVE_API_KEY=""

# ID папки в Google Drive для синхронизации документов
# Формат: строка из URL папки (например: 1d9_a3NQ2hHioMJsaUJ53NIj-CS1rVeDd)
GOOGLE_DRIVE_FOLDER_ID=""

# ============================================================================
# 1C ODATA (ОПЦИОНАЛЬНО, НО ОБЯЗАТЕЛЬНО ДЛЯ /api/integrations/1c/sync)
# ============================================================================

# URL OData-контура 1C
ONEC_BASE_URL=""

# Логин 1C для Basic Auth
ONEC_USER=""

# Пароль 1C для Basic Auth
ONEC_PASSWORD=""

# Таймаут запросов к 1C в миллисекундах
ONEC_TIMEOUT_MS="60000"

# Cron выражение для фоновой синхронизации 1C
ONEC_CRON_SCHEDULE="*/15 * * * *"

# ============================================================================
# STRIPE / SaaS Billing
# ============================================================================

# Stripe secret key (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=""

# Stripe webhook endpoint signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs mapped to tiers
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ENTERPRISE=""

# ============================================================================
# SMTP (tenant data export emails)
# ============================================================================

SMTP_HOST="localhost"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@erp-saas.com"

# Billing page URL (used in subscription lock responses)
BILLING_PAGE_URL="/billing"